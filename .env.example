# Copy to .env and fill in if you want. ALL OPTIONAL — no API key is required.
# The AI analysis is done by your Claude Code session, not a hosted API.

# NCBI E-utilities API key — optional; raises PubMed rate limit from 3 to 10 req/s.
NCBI_API_KEY=

# Email sent to NCBI / OpenAlex / Crossref (politeness pools — faster, more reliable).
NCBI_TOOL_EMAIL=

# Semantic Scholar API key — optional; needed for the Semantic Scholar source (it 429s without).
S2_API_KEY=
